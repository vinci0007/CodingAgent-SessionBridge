{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "xfer",
  "version": "0.1.1",
  "identifier": "com.xfer.desktop",
  "build": {
    "frontendDist": "../dist-ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "xfer",
        "width": 1280,
        "height": 860,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "targets": "all"
  },
  "plugins": {}
}
